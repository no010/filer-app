{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "filer",
  "version": "0.1.0",
  "identifier": "com.filer.app",
  "build": {
    "frontendDist": "../ui/dist",
    "devUrl": "http://localhost:1422",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "filer 下载整理",
        "width": 1100,
        "height": 750,
        "minWidth": 800,
        "minHeight": 500,
        "dragDropEnabled": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/icon.png",
      "icons/icon.ico"
    ]
  }
}
