{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "filer",
  "version": "0.1.0",
  "identifier": "com.filer.app",
  "build": {
    "frontendDist": "../ui/dist",
    "devUrl": "http://localhost:1422",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "filer 下载整理",
        "width": 1100,
        "height": 750,
        "minWidth": 800,
        "minHeight": 500,
        "dragDropEnabled": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEIxOUFBNUQyQjU1RTE1MDQKUldRRUZYNjEwcVdhc1ZsSmFGVFlkQmQ5YlM4VStnT2FaNjBpKzJVVkYybXNCMnV3Q295M2ZldU8K",
      "endpoints": [
        "https://github.com/no010/filer-app/releases/latest/download/latest.json"
      ]
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/icon.png",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "installerHooks": "nsis/hooks.nsi"
      }
    }
  }
}
